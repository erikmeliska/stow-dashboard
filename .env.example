# Directories to scan (comma-separated)
SCAN_ROOTS=/Users/joe/projects

# Base directory for relative paths in dashboard
BASE_DIR=/Users/joe/projects

# Terminal apps offered by "Open in Terminal" — first one is the default
# Examples: Terminal, Warp, iTerm, cmux
# (legacy single-value TERMINAL_APP is still honored)
TERMINAL_APPS=Terminal,Warp

# IDE commands offered by "Open in IDE" — first one is the default
# Examples: code, cursor, zed
# (legacy single-value IDE_COMMAND is still honored)
IDE_COMMANDS=code,cursor

# Ollama fallback for AI analysis of projects the on-device model rejects
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=llama3
